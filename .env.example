# Supabase 配置
# 在 Supabase 控制台 -> Project Settings -> API 获取
# 复制此文件为 .env.local 并填入真实值

# 公开值（前端可见，用于浏览器直连，受 RLS 保护）
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxx
# 仅服务端使用（不要暴露给浏览器！用于 Route Handler 绕过 RLS）
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxxxxxx